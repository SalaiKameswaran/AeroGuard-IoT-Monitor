      "source": [
        "BASE_DIR = '/content/dataset/mit-bih-arrhythmia-database-1.0.0'\n",
        "\n",
        "def bandpass_filter(signal, fs=360, lowcut=0.5, highcut=40.0, order=4):\n",
        "    from scipy.signal import butter, filtfilt\n",
        "    nyq  = 0.5 * fs\n",
        "    b, a = butter(order, [lowcut/nyq, highcut/nyq], btype='band')\n",
        "    return filtfilt(b, a, signal)\n",
        "\n",
        "def notch_filter(signal, fs=360, freq=50.0, quality=30):\n",
        "    from scipy.signal import iirnotch, filtfilt\n",
        "    b, a = iirnotch(freq / (0.5 * fs), quality)\n",
        "    return filtfilt(b, a, signal)\n",
        "\n",
        "def preprocess(signal, fs=360):\n",
        "    signal = bandpass_filter(signal, fs)\n",
        "    signal = notch_filter(signal, fs)\n",
        "    return signal\n",
        "\n",
        "AAMI_MAP = {\n",
        "    'N':'N', 'L':'N', 'R':'N', 'e':'N', 'j':'N',\n",
        "    'A':'S', 'a':'S', 'J':'S', 'S':'S',\n",
        "    'V':'V', 'E':'V',\n",
        "    'F':'F',\n",
        "    '/':'Q', 'f':'Q', 'Q':'Q'\n",
        "}\n",
        "\n",
        "BEFORE = 90\n",
        "AFTER  = 110\n",
        "WIN    = BEFORE + AFTER\n",
        "\n",
        "DS1 = ['101','106','108','109','112','114','115','116','118','119',\n",
        "       '122','124','201','203','205','207','208','209','215','220',\n",
        "       '223','230']\n",
        "\n",
        "DS2 = ['100','103','105','111','113','117','121','123','200','202',\n",
        "       '210','212','213','214','219','221','222','228','231','232',\n",
        "       '233','234']\n",
        "\n",
        "def extract_beats_local(record_id, base_dir=BASE_DIR):\n",
        "    record_path = None\n",
        "    for root, dirs, files_list in os.walk(base_dir):\n",
        "        for f in files_list:\n",
        "            if f == record_id + '.hea':\n",
        "                record_path = os.path.join(root, record_id)\n",
        "                break\n",
        "    if record_path is None:\n",
        "        raise FileNotFoundError(f\"Record {record_id} not found\")\n",
        "    rec = wfdb.rdrecord(record_path)\n",
        "    ann = wfdb.rdann(record_path, 'atr')\n",
        "    sig = preprocess(rec.p_signal[:, 0])\n",
        "    beats  = []\n",
        "    labels = []\n",
        "    for i, sym in zip(ann.sample, ann.symbol):\n",
        "        if sym not in AAMI_MAP:\n",
        "            continue\n",
        "        if i - BEFORE < 0 or i + AFTER > len(sig):\n",
        "            continue\n",
        "        beats.append(sig[i - BEFORE : i + AFTER])\n",
        "        labels.append(AAMI_MAP[sym])\n",
        "    return np.array(beats), np.array(labels)\n",
        "\n",
        "def load_dataset_local(record_list, label='DS'):\n",
        "    all_beats  = []\n",
        "    all_labels = []\n",
        "    for i, rid in enumerate(record_list):\n",
        "        print(f\"  Loading {label} {rid}  ({i+1}/{len(record_list)})\", end='\\r')\n",
        "        try:\n",
        "            beats, labels = extract_beats_local(rid)\n",
        "            all_beats.append(beats)\n",
        "            all_labels.append(labels)\n",
        "        except Exception as e:\n",
        "            print(f\"\\n  Skipped {rid}: {e}\")\n",
        "    if not all_beats:\n",
        "        raise ValueError(\"No beats loaded — check BASE_DIR\")\n",
        "    return np.vstack(all_beats), np.concatenate(all_labels)\n",
        "\n",
        "print(\"Functions ready!\")"
